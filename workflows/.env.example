# CRE workflow environment
# Copy to .env and fill values (do not commit .env)

# Target: base-sepolia or base-mainnet (must match project.yaml)
CRE_TARGET=base-sepolia

# Private key for signing transactions (hex, no 0x prefix)
# Used by secrets.yaml as env var for CRE_ETH_PRIVATE_KEY
ETH_PRIVATE_KEY=

# Optional RPC overrides (override project.yaml defaults)
# RPC_ETHEREUM_TESTNET_SEPOLIA_BASE_1=https://...
# RPC_ETHEREUM_MAINNET_BASE_1=https://...
